@model DuAnThuongMaiDienTu.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<h2>@Model.Name</h2>

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" />
        }
    </div>
    <div class="col-md-6">
        <h3>Giá: @Model.Price.ToString("N0") đ</h3>
        <p><strong>Mô tả:</strong> @Model.Description</p>
        <p><strong>Danh mục:</strong> @Model.Category?.Name</p>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>
